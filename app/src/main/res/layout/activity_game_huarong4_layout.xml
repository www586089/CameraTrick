                android:gravity="center"
                android:maxLines="1"
                android:text="5"
                android:textSize="50sp"
                app:autoSizeMaxTextSize="50sp"
                app:autoSizeMinTextSize="24sp"
                app:autoSizeTextType="uniform" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/number_5"
