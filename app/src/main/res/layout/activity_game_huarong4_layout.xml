                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="#9F67c8ff"
                android:ellipsize="end"
                android:foreground="?android:attr/selectableItemBackground"
                android:gravity="center"
                android:maxLines="1"
                android:text="10"
