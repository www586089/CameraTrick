<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/purple_200"
    android:clipChildren="false"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#80aa6688"
        android:clipChildren="false"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:clipChildren="false">

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/number_0"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="#aa67c8ff"
                android:gravity="center"
                android:text="1"
                android:textSize="50sp" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/number_1"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="#9967c8ff"
                android:gravity="center"
                android:text="2"
                android:textSize="50sp" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/number_2"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="#8867c8ff"
                android:gravity="center"
                android:text="3"
                android:textSize="50sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:clipChildren="false">

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/number_3"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="#7767c8ff"
                android:gravity="center"
                android:text="4"
                android:textSize="50sp" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/number_4"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="#6667c8ff"
                android:gravity="center"
                android:text="5"
                android:textSize="50sp" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/number_5"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="#5567c8ff"
                android:gravity="center"
                android:text="6"
                android:textSize="50sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:clipChildren="false">

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/number_6"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="#4467c8ff"
                android:gravity="center"
                android:text="7"
                android:textSize="50sp" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/number_7"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="#3367c8ff"
                android:gravity="center"
                android:text="8"
                android:textSize="50sp" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/number_8"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="#2267c8ff"
                android:gravity="center"
                android:text=""
                android:textSize="50sp" />
        </LinearLayout>
    </LinearLayout>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="72dp">

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/game_step"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true"
            android:textSize="34sp" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/reset"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:gravity="center"
            android:paddingHorizontal="12dp"
            android:text="重置"
            android:textSize="24sp" />
    </RelativeLayout>

</LinearLayout>